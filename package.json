{
  "name": "naturabridgeb-app",
  "version": "1.0.0",
  "description": "NaturaBridgeB â€” Business Edition Â· iPhone, iPad & Mac (Capacitor + Mac Catalyst)",
  "private": true,
  "scripts": {
    "sync": "cap sync ios",
    "open:ios": "cap open ios",
    "build:ios": "cap sync ios && cap open ios",
    "build:mac": "cap sync ios && cap open ios",
    "electron": "electron .",
    "build:win": "electron-builder --win --publish never"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "main": "electron-main.js",
  "build": {
    "appId": "com.naturabridge.business",
    "productName": "NaturaBridgeB",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "www/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "www/icon.ico",
      "shortcutName": "NaturaBridgeB"
    },
    "files": [
      "www/**/*",
      "electron-main.js",
      "package.json"
    ]
  }
}
