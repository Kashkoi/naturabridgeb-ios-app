.env
.env.local
*.p8
*.p12
*.cer
*.mobileprovision

# ── Build output ─────────────────────────────────────────────────────
dist/
build/
*.ipa
*.pkg
*.xcarchive

# ── Logs ─────────────────────────────────────────────────────────────
*.log
logs/
